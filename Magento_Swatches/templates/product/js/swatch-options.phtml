use Hyva\Theme\ViewModel\HyvaCsp;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

/** @var Template $block */
/** @var Escaper $escaper */
/** @var HyvaCsp $hyvaCsp */

?>
<script>
    function initSwatchOptions() {
        return {
            activeTooltipItem: false,
            tooltipPositionElement: false,
            isTooltipVisible() {
                return !!this.activeTooltipItem;
            },
            isCurrentTooltipVisual() {
                return this.activeTooltipItem && ['color', 'image'].includes(this.activeTooltipItem.type);
            },
            getTooltipImageStyle() {
                const item = this.activeTooltipItem;
                if (item?.type === 'color') return {
                    backgroundColor: item.preview,
                    width: `${item.width ?? 90}px`,
                    height: `${item.height ?? 90}px`
                };
                if (item?.type === 'image') return {
                    backgroundImage: `url(${item.preview})`,
                    backgroundSize: 'cover',
                    backgroundPosition: 'center',
                    backgroundRepeat: 'no-repeat',
                    width: `${item.width ?? 90}px`,
                    height: `${item.height ?? 90}px`
                };
                return null;
            },
            getTooltipPosition() {
                if (!this.tooltipPositionElement) return null;
                const el = this.tooltipPositionElement;
                const elRect = el.getBoundingClientRect();
                const overflowEl = el.closest('.snap-track') || el.closest('[class*="overflow-x"]');
                let left = elRect.left + elRect.width / 2;

                if (overflowEl) {
                    const overflowRect = overflowEl.getBoundingClientRect();
                    left = Math.max(overflowRect.left, Math.min(overflowRect.right, left));
                }

                return {
                    bottom: `${window.innerHeight - elRect.top}px`,
                    left: `${left}px`,
                    translate: '-50% 0'
                };
            },
            getTooltipLabel() {
                return this.activeTooltipItem ? this.activeTooltipItem.label : '';
            },
            showTooltip(event) {
                const input = event.currentTarget.querySelector('input');
                this.activeTooltipItem = JSON.parse(input.dataset.tooltip);
                this.tooltipPositionElement = event.currentTarget;
            },
            hideTooltip() {
                this.activeTooltipItem = false;
            },
            <?php
            /*
             * @deprecated
             * The following methods are empty stubs kept for backwards compatibility with third-party code that may
             * call them, but they no longer work.
             */
            ?>
            getAttributeSwatchData(attributeId) {},
            mapSwatchTypeNumberToTypeCode(typeNumber) {},
            getTypeOfFirstOption(attributeId) {},
            getVisualSwatchType(attributeId, targetOptionId) {},
            getSwatchType(attributeId, optionId) {},
            isTextSwatch(attributeId, optionId) {},
            isVisualSwatch(attributeId, optionId) {},
            getSwatchBackgroundStyle(attributeId, optionId) {},
            getSwatchText(attributeId, optionId) {},
            getOptionLabelFromOptionConfig(attributeId, optionId) {},
            getSwatchConfig(attributeId, optionId) {},
            isFirstItemCol() {},
            focusedLabel: false,
            focusLabel(optionId) {},
            blurLabel() {}
        }
    }
</script>
